# ============================================
# PyAgent 完整配置文件
# ============================================
# 说明：
# 1. 复制此文件为 .env
# 2. 根据需要修改配置
# 3. config.yaml 文件是可选的，.env 优先级更高
# 4. 所有配置都有默认值，只需配置需要修改的项

# ============================================
# 模型选择
# ============================================
MODEL_TYPE=glm                 # claude | openai | glm | qwen | deepseek | kimi | local

# ============================================
# GLM (智谱AI) 配置 - 推荐使用
# ============================================
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
GLM_MODEL=glm-4-flash          # glm-4-flash | glm-4-plus | glm-4-air
GLM_MAX_TOKENS=4096
GLM_TEMPERATURE=0.7
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============================================
# OpenAI 配置
# ============================================
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.7
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Claude 配置
# ============================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_MAX_TOKENS=4096
# CLAUDE_TEMPERATURE=0.7
# CLAUDE_BASE_URL=https://api.anthropic.com

# ============================================
# Qwen (通义千问) 配置
# ============================================
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# QWEN_MODEL=qwen-turbo
# QWEN_MAX_TOKENS=4096
# QWEN_TEMPERATURE=0.7
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# ============================================
# DeepSeek 配置
# ============================================
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_TOKENS=4096
# DEEPSEEK_TEMPERATURE=0.7
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================
# Kimi (月之暗面) 配置
# ============================================
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# KIMI_MODEL=moonshot-v1-8k
# KIMI_MAX_TOKENS=4096
# KIMI_TEMPERATURE=0.7
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# ============================================
# 本地模型 (Ollama) 配置
# ============================================
# LOCAL_MODEL_ENDPOINT=http://localhost:11434
# LOCAL_MODEL=codellama
# LOCAL_MAX_TOKENS=2048

# ============================================
# 知识库配置
# ============================================
USE_VECTOR_DB=true             # 是否使用向量数据库
OFFLINE_MODE=false             # 离线模式
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./data/models/sentence_transformers
FILE_STORE_PATH=./data/knowledge
VECTOR_DB_PATH=./data/vector_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ============================================
# 学习配置
# ============================================
LEARNING_SCHEDULE=02:00        # 每日学习时间
MAX_DAILY_LEARNINGS=20         # 每日最大学习条目数

# ============================================
# 日报配置
# ============================================
REPORT_PATH=./data/reports
MAX_REPORT_ITEMS=10

# ============================================
# CLI 配置
# ============================================
MAX_HISTORY=100
HISTORY_FILE=./data/history.json

# ============================================
# 守护进程配置
# ============================================
PID_FILE=./data/daemon.pid
LOG_FILE=./data/logs/daemon.log
CHECK_INTERVAL=60              # 检查间隔(秒)

# ============================================
# Agent 信息
# ============================================
AGENT_NAME=PyAgent
AGENT_VERSION=0.1.0

# ============================================
# 其他环境变量
# ============================================
# 嵌入模型缓存（可选）
# SENTENCE_TRANSFORMERS_HOME=./data/models/sentence_transformers
# TRANSFORMERS_CACHE=./data/models
# HF_HUB_OFFLINE=1

# 搜索API（可选）
# SERPER_API_KEY=your_serper_api_key_here

# ============================================
# 使用说明
# ============================================
#
# 最小配置（只需设置这三行）：
#   MODEL_TYPE=glm
#   ZHIPUAI_API_KEY=your_key
#   GLM_MODEL=glm-4-flash
#
# 启动命令：
#   myagent init      # 初始化
#   myagent learn     # 开始学习
#   myagent chat      # 交互对话
#   myagent report    # 查看日报
